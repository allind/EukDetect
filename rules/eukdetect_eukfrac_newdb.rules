
#targets

rule runall:
	input:
		expand("{output_dir}/aln/{sample}_aln_q10_lenfilter.sorted.bam", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam.bai", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/filtering/{sample}_read_counts_and_mismatches.txt", sample=config["samples"], output_dir=config["output_dir"]), 
		expand("{output_dir}/filtering/{sample}_all_hits_table.txt", sample=config["samples"], output_dir=config["output_dir"]), 
		expand("{output_dir}/{sample}_filtered_hits_table.txt", sample=config["samples"], output_dir=config["output_dir"]), 
		expand("{output_dir}/{sample}_filtered_hits_eukfrac.txt", sample=config["samples"], output_dir=config["output_dir"])

rule printaln:
	input:
		expand("{output_dir}/alignment_commands.txt", output_dir=config["output_dir"])

rule aln:
	input:	
		expand("{output_dir}/aln/{sample}_aln_q10_lenfilter.sorted.bam", sample=config["samples"], output_dir=config["output_dir"])

rule filter:
	input:
		expand("{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam.bai", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/filtering/{sample}_read_counts_and_mismatches.txt", sample=config["samples"], output_dir=config["output_dir"]), 
		expand("{output_dir}/filtering/{sample}_all_hits_table.txt", sample=config["samples"], output_dir=config["output_dir"]), 
		expand("{output_dir}/{sample}_filtered_hits_table.txt", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/{sample}_filtered_hits_eukfrac.txt", sample=config["samples"], output_dir=config["output_dir"])

#rules

rule alncmd:
	output:
		"{output_dir}/alignment_commands.txt"
	run:
		import os
		db = os.path.join(config["database_dir"], config["database_prefix"])
		samples = config["samples"]
		output_dir = config["output_dir"]
		fq_dir = config["fq_dir"]
		paired_end = config["paired_end"]
		readlen = config["readlen"]
		minreadlen = max(60, int(round(readlen * 0.8)))

		with open(output[0], "w") as out:
			for sample in samples:
				if paired_end:
					r1 = os.path.join(fq_dir, f"{sample}{config['fwd_suffix']}")
					r2 = os.path.join(fq_dir, f"{sample}{config['rev_suffix']}")
					bam = os.path.join(output_dir, f"aln/{sample}_aln_q10_lenfilter.sorted.bam")
					cmd = (
						f"bowtie2 --quiet --omit-sec-seq --no-discordant --no-unal -x {db} "
						f"-1 {r1} -2 {r2} | "
						f"perl -lane '{{ $l=0; $F[5]=~s/(\\d+)[MX=DN]/$l+=$1/eg; print if $l > {minreadlen} or /^@/ }}' | "
						f"samtools view -q 30 -bS - | samtools sort -o {bam} -")
				else:
					fq = os.path.join(fq_dir, f"{sample}{config['se_suffix']}")
					bam = os.path.join(output_dir, f"aln/{sample}_aln_q10_lenfilter.sorted.bam")
					cmd = (
					f"bowtie2 --quiet --omit-sec-seq --no-discordant --no-unal -x {db} "
					f"-U {fq} | "
					f"perl -lane '{{ $l=0; $F[5]=~s/(\\d+)[MX=DN]/$l+=$1/eg; print if $l > {minreadlen} or /^@/ }}' | "
					f"samtools view -q 30 -bS - | samtools sort -o {bam} -")
				out.write(cmd + "\n")


rule runaln:
	input:
		r1 = lambda wildcards: config["fq_dir"] + "/" + wildcards.sample + (config["fwd_suffix"] if config["paired_end"] else config["se_suffix"]),
                r2 = lambda wildcards: config["fq_dir"] + "/" + wildcards.sample + (config["rev_suffix"] if config["paired_end"] else config["se_suffix"])
	output:
		bam = "{output_dir}/aln/{sample}_aln_q10_lenfilter.sorted.bam"
	run:
		import os
		db = os.path.join(config["database_dir"], config["database_prefix"])
		readlen=config["readlen"]
		minreadlen = round(readlen * 0.8, 0)
		if minreadlen < 60:
			minreadlen = 60
		if config["paired_end"]:
			shell("""
			bowtie2 --quiet --omit-sec-seq --no-discordant --no-unal -x {db} -1 {input.r1} -2	{input.r2} | 
			perl -lane '$l = 0; $F[5] =~ s/(\d+)[MX=DN]/$l+=$1/eg; print if $l > {minreadlen} or /^@/' |
			samtools view -q 30 -bS - |
			samtools sort -o {output.bam} - 
			""")
		else:
			shell("""
			bowtie2 --quiet --omit-sec-seq --no-discordant --no-unal -x {db} -U {input.r1} | 
			perl -lane '$l = 0; $F[5] =~ s/(\d+)[MX=DN]/$l+=$1/eg; print if $l > {minreadlen} or /^@/' | 
			samtools view -q 30 -bS - | 
			samtools sort -o {output.bam} - 
			""")


rule bam2fastq:
	input:
		bam = "{output_dir}/aln/{sample}_aln_q10_lenfilter.sorted.bam"
	output:
		temp("{output_dir}/aln/{sample}_aln_q10_lenfilter.fq")
	shell:
		"bedtools bamtofastq -i {input.bam} -fq {output}"

rule find_low_complexity:
	input:
		fq = "{output_dir}/aln/{sample}_aln_q10_lenfilter.fq"
	output:
		temp("{output_dir}/aln/{sample}_low_complexity.txt")

	shell:
		"cat {input.fq} | kz | awk '{{ if ($4<0.5) print $1 }}' > {output}"

rule remove_low_complexity:
	input:
		inbam = "{output_dir}/aln/{sample}_aln_q10_lenfilter.sorted.bam",
		drop_complex ="{output_dir}/aln/{sample}_low_complexity.txt"
	output:
		temp("{output_dir}/aln/{sample}_aln_q10_lenfilter_complexity.sorted.bam")

	run:
		low_complex = open(input.drop_complex).readlines()
		if len(low_complex) > 0:
			shell("samtools view -h {input.inbam} | grep -v -f {input.drop_complex} | samtools view -bS - > {output}")
		else:
			shell("samtools view -h {input.inbam} | samtools view -bS - > {output}")


rule fixmate:
	input:
		inbam = "{output_dir}/aln/{sample}_aln_q10_lenfilter_complexity.sorted.bam"
	output:
		temp("{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexity_fixmate.bam")
	shell:
		"""
		samtools sort -n {input.inbam} | samtools fixmate -m - {output}

		"""
rule markdup:
	input:
		"{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexity_fixmate.bam"
	output:
		temp("{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexity_rmdup.bam")
	shell:
		"""
		samtools sort {input} | samtools markdup -r -s - {output}

		"""
rule rmsort:
	input:
		"{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexity_rmdup.bam"
	output:
		"{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam"

	shell:
		"""
		samtools sort -o {output} {input}
		"""	

rule index:
	input:
		bam = "{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam"
	output:
		bai = "{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam.bai"

	shell:
		"samtools index {input.bam} {output.bai}"

rule countreads:
	input:
		bam = "{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam",
		bai = "{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam.bai",
		countscript = expand("{eukdetect_dir}/eukdetect/bam_to_pid.py", eukdetect_dir=config["eukdetect_dir"]),
		ref = expand("{tax_dir}/{db}.fasta", tax_dir=config["database_dir"], db=config["database_prefix"])
	output:
		counts = "{output_dir}/filtering/{sample}_read_counts_and_mismatches.txt"
	shell:
		"python {input.countscript} {input.bam} {input.ref} > {output.counts}"

rule taxonomize:
	input:
		counts = "{output_dir}/filtering/{sample}_read_counts_and_mismatches.txt",
		script = expand("{eukdetect_dir}/eukdetect/count_primary_and_secondary_eukfrac_newdb.py", eukdetect_dir=config["eukdetect_dir"]),
		taxid_link = expand("{tax_dir}/busco_taxid_genome_link.txt", tax_dir=config["database_dir"]),
		inherited_markers = expand("{tax_dir}/specific_and_inherited_markers_per_taxid.txt", tax_dir=config["database_dir"]),
		taxdb = expand("{tax_dir}/taxa.sqlite", tax_dir=config["database_dir"]),
		genelens = expand("{tax_dir}/taxid_and_genome_cumulativelength.txt", tax_dir=config["database_dir"])
	output:
		allhits = "{output_dir}/filtering/{sample}_all_hits_table.txt",
		primary_hits = "{output_dir}/{sample}_filtered_hits_table.txt",
		primary_eukfrac ="{output_dir}/{sample}_filtered_hits_eukfrac.txt"
	shell:
		"python {input.script} --dbfile {input.taxdb} --taxid_link {input.taxid_link} --inherited_markers {input.inherited_markers} --taxid_genelens {input.genelens} --readcounts {input.counts} --primarytab {output.primary_hits} --eukfrac {output.primary_eukfrac} --alltab {output.allhits}"
