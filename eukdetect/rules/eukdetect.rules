import os as _os
_EUKDETECT_DIR    = config["eukdetect_dir"]
_BAM_TO_PID       = _os.path.join(_EUKDETECT_DIR, "util", "bam_to_pid.py")
_EUKFRAC_CALC     = _os.path.join(_EUKDETECT_DIR, "util", "eukfrac_calc.py")
_COMPLEXITY_FILTER = _os.path.join(_EUKDETECT_DIR, "util", "complexity_filter.py")

#Target rules

rule all:
	input:
		expand("{output_dir}/aln/{sample}_aln_q10_lenfilter.sorted.bam", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam.bai", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/filtering/{sample}_read_counts_and_mismatches.txt", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/filtering/{sample}_all_hits_table.txt", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/{sample}_filtered_hits_table.txt", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/{sample}_filtered_hits_eukfrac.txt", sample=config["samples"], output_dir=config["output_dir"])

rule printaln:
	input:
		config["output_dir"] + "/alignment_commands.txt"

rule aln:
	input:
		expand("{output_dir}/aln/{sample}_aln_q10_lenfilter.sorted.bam", sample=config["samples"], output_dir=config["output_dir"])

rule analyze:
	input:
		expand("{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam.bai", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/filtering/{sample}_read_counts_and_mismatches.txt", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/filtering/{sample}_all_hits_table.txt", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/{sample}_filtered_hits_table.txt", sample=config["samples"], output_dir=config["output_dir"]),
		expand("{output_dir}/{sample}_filtered_hits_eukfrac.txt", sample=config["samples"], output_dir=config["output_dir"])


#Alignment

rule alncmd:
	output:
		config["output_dir"] + "/alignment_commands.txt"
	run:
		import os
		db = os.path.join(config["database_dir"], config["database_prefix"])
		samples = config["samples"]
		output_dir = config["output_dir"]
		fq_dir = config["fq_dir"]
		paired_end = config["paired_end"]
		readlen = config["readlen"]
		cores = config.get("bowtie2_cores", 1)
		minreadlen = max(60, int(round(readlen * 0.8)))

		with open(output[0], "w") as out:
			for sample in samples:
				if paired_end:
					sample_info = samples.get(sample)
					if sample_info and isinstance(sample_info, dict) and "reads1" in sample_info:
						r1 = sample_info["reads1"]
						r2 = sample_info.get("reads2", os.path.join(fq_dir, f"{sample}{config['rev_suffix']}"))
					else:
						r1 = os.path.join(fq_dir, f"{sample}{config['fwd_suffix']}")
						r2 = os.path.join(fq_dir, f"{sample}{config['rev_suffix']}")
					bam = os.path.join(output_dir, f"aln/{sample}_aln_q10_lenfilter.sorted.bam")
					cmd = (
						f"bowtie2 -p {cores} --end-to-end --very-sensitive -X 1000.0"
						f" --quiet --omit-sec-seq --no-discordant --no-unal"
						f" -x {db} -1 {r1} -2 {r2} |"
						f" perl -lane '$l = 0; $F[5] =~ s/(\\d+)[MX=DN]/$l+=$1/eg;"
						f" print if $l > {minreadlen} or /^@/' |"
						f" samtools view -q 10 -bS - |"
						f" samtools sort -@ {cores} -o {bam} -"
					)
				else:
					sample_info = samples.get(sample)
					if sample_info and isinstance(sample_info, dict) and "reads1" in sample_info:
						fq = sample_info["reads1"]
					else:
						fq = os.path.join(fq_dir, f"{sample}{config['se_suffix']}")
					bam = os.path.join(output_dir, f"aln/{sample}_aln_q10_lenfilter.sorted.bam")
					cmd = (
						f"bowtie2 -p {cores} --end-to-end --very-sensitive"
						f" --quiet --omit-sec-seq --no-discordant --no-unal"
						f" -x {db} -U {fq} |"
						f" perl -lane '$l = 0; $F[5] =~ s/(\\d+)[MX=DN]/$l+=$1/eg;"
						f" print if $l > {minreadlen} or /^@/' |"
						f" samtools view -q 10 -bS - |"
						f" samtools sort -@ {cores} -o {bam} -"
					)
				out.write(cmd + "\n")


rule runaln:
	input:
		r1 = lambda wildcards: (
			config["samples"][wildcards.sample]["reads1"]
			if config["samples"].get(wildcards.sample) and isinstance(config["samples"][wildcards.sample], dict) and "reads1" in config["samples"][wildcards.sample]
			else os.path.join(config["fq_dir"], wildcards.sample + (config["fwd_suffix"] if config["paired_end"] else config["se_suffix"]))
		),
		r2 = lambda wildcards: (
			config["samples"][wildcards.sample]["reads2"]
			if config["paired_end"] and config["samples"].get(wildcards.sample) and isinstance(config["samples"][wildcards.sample], dict) and "reads2" in config["samples"][wildcards.sample]
			else (os.path.join(config["fq_dir"], wildcards.sample + config["rev_suffix"]) if config["paired_end"] else [])
		)
	output:
		bam = config["output_dir"] + "/aln/{sample}_aln_q10_lenfilter.sorted.bam"
	params:
		db = os.path.join(config["database_dir"], config["database_prefix"]),
		minreadlen = max(60, int(round(config["readlen"] * 0.8))),
		paired_end = config["paired_end"]
	threads: config.get("bowtie2_cores", 1)
	shell:
		"""
		set -euo pipefail
		if [ "{params.paired_end}" = "True" ]; then
			bowtie2 -p {threads} --end-to-end --very-sensitive -X 1000.0 \\
				--quiet --omit-sec-seq --no-discordant --no-unal \\
				-x {params.db} -1 {input.r1} -2 {input.r2} |
			perl -lane '$l = 0; $F[5] =~ s/(\\d+)[MX=DN]/$l+=$1/eg; print if $l > {params.minreadlen} or /^@/' |
			samtools view -q 10 -bS - |
			samtools sort -@ {threads} -o {output.bam} -
		else
			bowtie2 -p {threads} --end-to-end --very-sensitive \\
				--quiet --omit-sec-seq --no-discordant --no-unal \\
				-x {params.db} -U {input.r1} |
			perl -lane '$l = 0; $F[5] =~ s/(\\d+)[MX=DN]/$l+=$1/eg; print if $l > {params.minreadlen} or /^@/' |
			samtools view -q 10 -bS - |
			samtools sort -@ {threads} -o {output.bam} -
		fi
		"""


#Filtering

rule complexity_and_dedup:
	input:
		bam = config["output_dir"] + "/aln/{sample}_aln_q10_lenfilter.sorted.bam"
	output:
		bam = config["output_dir"] + "/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam"
	params:
		script = _COMPLEXITY_FILTER
	shell:
		"python {params.script} {input.bam} {output.bam}"


#Index

rule index:
	input:
		bam = config["output_dir"] + "/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam"
	output:
		bai = config["output_dir"] + "/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam.bai"
	shell:
		"samtools index {input.bam} {output.bai}"

#Count

rule countreads:
	input:
		bam = config["output_dir"] + "/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam",
		bai = config["output_dir"] + "/filtering/{sample}_aln_q10_lenfilter_complexityfilter_dupfilter.sorted.bam.bai",
		ref = config["database_dir"] + "/" + config["database_prefix"] + ".fasta"
	output:
		counts = config["output_dir"] + "/filtering/{sample}_read_counts_and_mismatches.txt"
	params:
		script = _BAM_TO_PID
	shell:
		"python {params.script} {input.bam} {input.ref} > {output.counts}"
#taxonomy

rule taxonomize:
	input:
		counts            = config["output_dir"] + "/filtering/{sample}_read_counts_and_mismatches.txt",
		taxid_link        = config["database_dir"] + "/busco_taxid_genome_link.txt",
		inherited_markers = config["database_dir"] + "/specific_and_inherited_markers_per_taxid.txt",
		taxdb             = config["database_dir"] + "/taxa.sqlite",
		genelens          = config["database_dir"] + "/taxid_and_genome_cumulativelength.txt"
	output:
		allhits         = config["output_dir"] + "/filtering/{sample}_all_hits_table.txt",
		primary_hits    = config["output_dir"] + "/{sample}_filtered_hits_table.txt",
		primary_eukfrac = config["output_dir"] + "/{sample}_filtered_hits_eukfrac.txt"
	params:
		script = _EUKFRAC_CALC
	shell:
		"""
		python {params.script} \\
			--dbfile            {input.taxdb} \\
			--taxid_link        {input.taxid_link} \\
			--inherited_markers {input.inherited_markers} \\
			--taxid_genelens    {input.genelens} \\
			--readcounts        {input.counts} \\
			--primarytab        {output.primary_hits} \\
			--eukfrac           {output.primary_eukfrac} \\
			--alltab            {output.allhits}
		"""

